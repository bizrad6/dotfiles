[core]
	editor = nano
	excludesFile = ~/.gitignore_global
	autocrlf = input
	whitespace = trailing-space,space-before-tab

[color]
	ui = auto

[color "diff"]
	meta       = yellow bold
	frag       = magenta bold
	old        = red bold
	new        = green bold
	whitespace = red reverse

[push]
	default = current
	autoSetupRemote = true

[pull]
	rebase = false

[fetch]
	prune = true

[diff]
	algorithm = histogram
	colorMoved = zebra

[merge]
	conflictstyle = zdiff3

[rebase]
	autoStash = true
	autoSquash = true

[log]
	date = relative

[alias]
	# Pretty log
	lg  = log --oneline --graph --decorate --all
	# Show files changed in last commit
	last = diff HEAD~1..HEAD --name-only
	# Undo last commit, keep changes staged
	undo = reset --soft HEAD~1
	# List branches sorted by last commit date
	recent = branch --sort=-committerdate --format='%(committerdate:relative)%09%(refname:short)'
	# Show stashes
	sl = stash list
	# Amend last commit without editing message
	fixup = commit --amend --no-edit
	# Squash all commits on this branch down to one (base defaults to main)
	squash-all = "!f() { base=${1:-main}; git reset --soft $(git merge-base origin/$base HEAD) && git commit --edit -m\"$(git log --format=%B --reverse HEAD..HEAD@{1} | head -1)\"; }; f"
	# Delete local branches whose remote tracking branch is gone
	brp = "!git fetch --prune && git branch -vv | grep ': gone]' | awk '{print $1}' | xargs -r git branch -d"
	# Fetch a base branch and rebase current branch onto it
	plr = "!f() { base=${1:-main}; git fetch origin $base:$base && git rebase $base; }; f"

